[Desktop Entry]
Type=Application
Version=1.5
Name=ChatGPT Work Linux (Unofficial)
GenericName=AI Work Assistant
Comment=Unofficial community Linux desktop application for ChatGPT Work
Exec=chatgpt-work-linux %u
TryExec=chatgpt-work-linux
Icon=io.github.chatgpt_work_linux
Terminal=false
Categories=Network;Chat;
Keywords=AI;assistant;chat;work;documents;research;
StartupNotify=true
StartupWMClass=io.github.chatgpt_work_linux
MimeType=x-scheme-handler/codex;
Actions=NewChat;QuickChat;SafeMode;

[Desktop Action NewChat]
Name=New Task
Exec=chatgpt-work-linux --new-chat

[Desktop Action QuickChat]
Name=Quick Chat
Exec=chatgpt-work-linux --quick-chat

[Desktop Action SafeMode]
Name=Open in Safe Mode
Exec=chatgpt-work-linux --safe-mode
